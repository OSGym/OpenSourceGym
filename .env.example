# Zorunlu: openssl rand -base64 32 ile üretin
BETTER_AUTH_SECRET=

# pnpm dev için compose Mongo/Redis adresleri (host portları 27018/6380).
# Boş bırakılırsa varsayılan 27017/6379 kullanılır — makinede sistem
# mongod/redis çalışıyorsa yanlış sunucuya bağlanılır.
MONGODB_URI=mongodb://127.0.0.1:27018/opengym-dev
REDIS_URL=redis://127.0.0.1:6380

# API'nin dışarıdan erişildiği adres
BETTER_AUTH_URL=http://localhost:3000

# Web panel origin'leri (virgülle ayrılır)
TRUSTED_ORIGINS=http://localhost:5173

# Cloudflare R2 — profil fotoğrafları
# R2_PUBLIC_BASE_URL bucket'a bağlı public custom domain olmalıdır
# (ör. https://media.example.com; production'da r2.dev kapalı tutulur).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# SMTP (boş bırakılırsa dev ortamında e-postalar konsola yazılır)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=OpenGym <noreply@opengym.local>
